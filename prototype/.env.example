# Copy to .env and edit before bringing the stack up.
# All secrets below are LOCAL DEMO values; replace them in any
# real deployment.

INGEST_MODE=kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
LOG_LEVEL=INFO

# Tenant identifiers (used as Kafka topic prefixes).
TENANTS=acme,globex,initech,somchart

# OAuth2 client credentials for the gateway (clientId:clientSecret;...).
# Replace these secrets before exposing the gateway.
OAUTH_CLIENTS=acme:CHANGE_ME;globex:CHANGE_ME;initech:CHANGE_ME;somchart:CHANGE_ME

# JWT signing key for gateway-issued bearer tokens. Replace before deploy.
GATEWAY_JWT_SECRET=CHANGE_ME

# Per-tenant alert webhook URLs.
WEBHOOKS=acme:http://webhook_receiver:9000/acme;globex:http://webhook_receiver:9000/globex;initech:http://webhook_receiver:9000/initech;somchart:http://webhook_receiver:9000/somchart

# Detection threshold tau* exported by pipeline/proposed_method_valcal.py.
# Update after retraining the cascade.
DETECT_TAU_STAR=0.0642566028502602
